APP_ENV=development

APP_DEBUG=true

DATABASE_URL=sqlite:///./app.db



# Trip chat API

API_HOST=0.0.0.0

API_PORT=8000

CHROMA_PERSIST_DIR=./data/chroma

AUTO_INDEX_TRIPS=true

TRIP_SOURCE=trvios

TRVIOS_TRIPS_API_URL=https://api.trvios.com/api/ai/trips



# Optional: enable OpenAI-powered answers (falls back to template RAG without it)

OPENAI_API_KEY=your_openai_api_key_here

OPENAI_MODEL=gpt-4o-mini

OPENAI_MODEL=gpt-4o-mini

# Optional: Sarvam AI API Key for Voice Agent (Hinglish STT / Bulbul v3 TTS)
SARVAM_API_KEY=

