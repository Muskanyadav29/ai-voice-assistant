      "name": "1. Unified API (Sync All-in-One Row)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"sync_all\",\n  \"faq_items\": [\n    {\n      \"question\": \"What is your cancellation policy?\",\n      \"answer\": \"Cancellation is allowed up to 48 hours before departure.\",\n      \"category\": \"Refunds\"\n    }\n  ],\n  \"website_url\": \"https://trvios.com/manali-guide\",\n  \"pdf_filename\": \"manali_guide.pdf\",\n  \"pdf_base64\": \"\",\n  \"sync_mongodb\": true,\n  \"query\": \"What is your cancellation policy?\",\n  \"destination\": \"Manali\",\n  \"duration_days\": 3,\n  \"budget_level\": \"moderate\",\n  \"travel_style\": \"mountains\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/unified",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "unified"
          ]
        },
        "description": "Executes FAQ training, Website training, PDF training, MongoDB trips training, AI Chat, and Itinerary Planning synchronously in 1 single row response."
      }
    },
